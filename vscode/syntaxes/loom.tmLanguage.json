{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Loom",
  "scopeName": "source.loom",
  "patterns": [
    { "include": "#comment" },
    { "include": "#foreignref" },
    { "include": "#projection" },
    { "include": "#join" },
    { "include": "#declaration" },
    { "include": "#keyword" },
    { "include": "#directive" },
    { "include": "#field" },
    { "include": "#builtin" },
    { "include": "#typeref" },
    { "include": "#string" },
    { "include": "#number" },
    { "include": "#operator" }
  ],
  "repository": {
    "comment": {
      "name": "comment.line.double-slash.loom",
      "match": "//.*$"
    },
    "foreignref": {
      "match": "\\b(consume|on)\\s+([a-z][A-Za-z0-9_]*)\\.([A-Za-z_][A-Za-z0-9_]*)",
      "captures": {
        "1": { "name": "keyword.control.loom" },
        "2": { "name": "entity.name.namespace.loom" },
        "3": { "name": "entity.name.type.event.loom" }
      }
    },
    "projection": {
      "match": "\\b(projection)\\s+([A-Za-z_][A-Za-z0-9_]*)\\s*(->)\\s*([A-Z][A-Za-z0-9_]*)",
      "captures": {
        "1": { "name": "storage.type.loom" },
        "2": { "name": "entity.name.type.loom" },
        "3": { "name": "keyword.operator.loom" },
        "4": { "name": "entity.name.type.reference.loom" }
      }
    },
    "join": {
      "match": "\\b(join)\\s+([a-z_][A-Za-z0-9_]*)\\s*(->)\\s*(\\[)?(?:([a-z][A-Za-z0-9_]*)\\.)?([A-Z][A-Za-z0-9_]*)(\\])?\\s+(via)\\s+([a-z_][A-Za-z0-9_]*)",
      "captures": {
        "1": { "name": "keyword.control.loom" },
        "2": { "name": "variable.other.member.loom" },
        "3": { "name": "keyword.operator.loom" },
        "5": { "name": "entity.name.namespace.loom" },
        "6": { "name": "entity.name.type.reference.loom" },
        "8": { "name": "keyword.control.loom" },
        "9": { "name": "variable.other.member.loom" }
      }
    },
    "declaration": {
      "match": "\\b(service|aggregate|record|entity|policy|process|projection|upload|upcast|consume|command|event|type)\\s+([A-Za-z_][A-Za-z0-9_]*)",
      "captures": {
        "1": { "name": "storage.type.loom" },
        "2": { "name": "entity.name.type.loom" }
      }
    },
    "keyword": {
      "name": "keyword.control.loom",
      "match": "\\b(on|state|effect|via|key|started|uploaded)\\b"
    },
    "directive": {
      "name": "storage.modifier.directive.loom",
      "match": "@[A-Za-z_][A-Za-z0-9_]*"
    },
    "field": {
      "match": "^\\s*([a-z_][A-Za-z0-9_]*)\\s*(?=:)",
      "captures": {
        "1": { "name": "variable.other.member.loom" }
      }
    },
    "builtin": {
      "name": "support.type.primitive.loom",
      "match": "\\b(string|int|float|bool|uuid|timestamp|bytes|file|any|map)\\b"
    },
    "typeref": {
      "name": "entity.name.type.reference.loom",
      "match": "\\b[A-Z][A-Za-z0-9_]*\\b"
    },
    "string": {
      "name": "string.quoted.double.loom",
      "match": "\"[^\"]*\""
    },
    "number": {
      "name": "constant.numeric.loom",
      "match": "-?\\b[0-9]+\\b"
    },
    "operator": {
      "name": "keyword.operator.loom",
      "match": "->|[!?]"
    }
  }
}
