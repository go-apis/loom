{
  "name": "loom-lang",
  "displayName": "Loom Schema Language",
  "description": "Syntax highlighting for Loom (.loom) event-sourcing schema files (v0.25 language)",
  "version": "0.2.0",
  "publisher": "inflow",
  "license": "MIT",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "contributes": {
    "languages": [
      {
        "id": "loom",
        "aliases": [
          "Loom",
          "loom"
        ],
        "extensions": [
          ".loom"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "loom",
        "scopeName": "source.loom",
        "path": "./syntaxes/loom.tmLanguage.json"
      }
    ]
  }
}
